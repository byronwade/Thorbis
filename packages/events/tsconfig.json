{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"outDir": "./dist",
		"rootDir": "./src",
		"composite": false,
		"jsx": "react-jsx",
		"baseUrl": ".",
		"paths": {
			"@/*": ["./src/*"]
		},
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"declaration": true,
		"declarationDir": "./dist",
		"skipLibCheck": true,
		"incremental": false,
		"allowJs": true,
		"esModuleInterop": true,
		"lib": ["dom", "dom.iterable", "esnext"],
		"types": ["react", "node"]
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.spec.ts"]
}
