{
	"extends": "../../packages/tsconfig/base.json",
	"compilerOptions": {
		"target": "ES2020",
		"module": "ESNext",
		"jsx": "react-jsx",
		"outDir": "./dist",
		"rootDir": "./src",
		"tsBuildInfoFile": "./dist/.tsbuildinfo",
		"declaration": true,
		"declarationDir": "./dist",
		"composite": true
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist"]
}
